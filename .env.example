# ============================================================
# .env.example — copy to .env and fill in your values
# NEVER commit .env to git (.gitignore already excludes it)
# ============================================================

# ── AWS Identity ────────────────────────────────────────────
# Option A: SSO (recommended)
AWS_PROFILE=musicstream-dev

# Option B: Long-lived keys (solo dev fallback — rotate regularly)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Region where all resources are deployed
AWS_REGION=eu-west-1

# ── Terraform Variables ──────────────────────────────────────
# Passed to Terraform as TF_VAR_* — matches variables.tf
TF_VAR_env=dev
TF_VAR_project=musicstream
TF_VAR_region=eu-west-1

# ── S3 Bucket Names (filled after terraform apply) ──────────
# These are outputs of the Terraform apply — fill them in after first deploy
# Run: terraform -chdir=infra/envs/dev output raw_bucket_name
RAW_BUCKET=musicstream-dev-raw
ARCHIVE_BUCKET=musicstream-dev-archive
QUARANTINE_BUCKET=musicstream-dev-quarantine
SCRIPTS_BUCKET=musicstream-dev-scripts
REFERENCE_BUCKET=musicstream-dev-reference

# ── DynamoDB Table Names ─────────────────────────────────────
GENRE_DAILY_TABLE=dev_genre_daily_kpi
TOP_SONGS_TABLE=dev_top_songs_daily
TOP_GENRES_TABLE=dev_top_genres_daily

# ── Step Functions ───────────────────────────────────────────
# Filled after terraform apply
# Run: terraform -chdir=infra/envs/dev output state_machine_arn
STATE_MACHINE_ARN=arn:aws:states:eu-west-1:ACCOUNT_ID:stateMachine:dev-streaming-etl-sm

# ── SQS Buffer Queue ─────────────────────────────────────────
# Run: terraform -chdir=infra/envs/dev output sqs_buffer_queue_url
SQS_BUFFER_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/ACCOUNT_ID/dev-etl-buffer

# ── Lambda ───────────────────────────────────────────────────
VALIDATE_SCHEMA_FUNCTION=dev-validate-schema

# ── UI Dashboard (Streamlit) ─────────────────────────────────
# Set to true to run the Streamlit dashboard without AWS credentials
# (uses fixture data from ui/lib/mock_data.py)
MOCK_MODE=false

# Streamlit default port (change if 8501 is in use)
UI_PORT=8501

# ── Terraform State Bootstrap ────────────────────────────────
# Only needed if re-bootstrapping state backend
# TF_STATE_BUCKET=musicstream-tfstate
# TF_STATE_LOCK_TABLE=musicstream-tfstate-lock

# ── Optional: Slack Notifications ───────────────────────────
# Webhook for the etl-ops SNS → Chatbot → Slack path
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Optional: Snyk Token (CI SAST) ───────────────────────────
# SNYK_TOKEN=...
